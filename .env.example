# ──────────────────────────────────────────────────────────────────────────────
# .env.example — PLANTILLA de variables de entorno.
#
# Cómo se usa:
#   1. Copia este archivo a uno llamado .env:   cp .env.example .env
#   2. Rellena los valores reales en .env (ese SÍ tiene tus secretos).
#   3. .env está en .gitignore, así que NUNCA se sube al repositorio.
#
# Este .example sí se versiona: documenta qué hace falta configurar, sin secretos.
# ──────────────────────────────────────────────────────────────────────────────

# Clave de la API de Google Gemini (la usa el LLM vía google-genai: normalización,
# reescritura a paisa y embeddings del RAG). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Token de Hugging Face. Chatterbox baja sus pesos de un repo PÚBLICO, así que NO es
# obligatorio, pero evita rate limits de descarga (y hace falta para repos privados).
# https://huggingface.co/settings/tokens
HF_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Eso es todo lo que hace falta acá: SECRETOS.
#
# Los ajustes de cómputo (STT_DEVICE, STT_MODEL_SIZE, STT_COMPUTE_TYPE, TTS_DEVICE)
# NO van acá: sus DEFAULTS viven en sus módulos (transcribe.py / synthesize.py).
# Agregá uno como env var SOLO si querés overridear su default, p. ej.:
#   STT_DEVICE=cuda
#
# (Nota: Chatterbox marca cada audio con una marca de agua neuronal imperceptible
# —PerTh, de Resemble AI—; es automática, no requiere configuración.)
# ──────────────────────────────────────────────────────────────────────────────
