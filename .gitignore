# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — qué NO se sube al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# Entorno virtual, bytecode y cachés (reconstruibles)
.venv
.cache
__pycache__/
*.py[cod]

# Secretos. La plantilla .env.example sí se versiona.
.env

# Material de archivo y salidas.
archive
outputs

# Config local de herramientas (Claude Code), metadata del SO y backups.
.DS_Store
.claude/
*.bak